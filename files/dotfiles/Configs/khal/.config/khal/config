[calendars]
[[gcal]]
path = ~/.calendars/gcal-dcal/
color = light blue

[[icloud]]
path = ~/.calendars/icloud-dcal/
color = light green

[locale]
timeformat = %I:%M %p
dateformat = %m/%d/%Y
longdateformat = %m/%d/%Y
datetimeformat = %m/%d/%Y %I:%M %p
longdatetimeformat = %m/%d/%Y %I:%M %p

[highlight_days]
color = #ea76cb
