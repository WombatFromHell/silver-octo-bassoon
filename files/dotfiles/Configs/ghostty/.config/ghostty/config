font-family = "JetBrains Mono Nerd Font"
# font-family = "FiraCode Nerd Font"
# font-family = "SourceCode Pro Nerd Font"
# font-family = "Hack Nerd Font"
font-size = 11.5
#
theme = catppuccin-mocha.conf
shell-integration = fish
bell-features = "system,title,attention,audio"
bell-audio-path = "/usr/share/sounds/freedesktop/stereo/message-new-instant.oga"
bell-audio-volume = 1.0
#
cursor-style = "block"
cursor-style-blink = true
#
gtk-tabs-location = hidden
gtk-single-instance = true
confirm-close-surface = false
background-opacity = 0.95
background-blur-radius = 20
window-save-state = always
quit-after-last-window-closed = true
keybind = shift+enter=text:\n
#
clipboard-read = allow
clipboard-write = allow
