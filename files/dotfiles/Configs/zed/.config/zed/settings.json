{
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 250,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },
  "cli_default_open_behavior": "existing_window",
  "context_servers": {
    "nixos": {
      "enabled": true,
      "remote": false,
      "command": "nix",
      "args": ["run", "github:utensils/mcp-nixos", "--"],
    },
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^nix\\s+flake(\\s|$)",
            },
            {
              "pattern": "^head\\b",
            },
          ],
        },
      },
    },
    "default_model": {
      "provider": "opencode",
      "model": "free/big-pickle",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "default_profile": "write",
    "model_parameters": [],
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "git_panel": {
    "dock": "left",
  },
  "lsp": {
    "nixd": {
      "binary": { "path": "~/.nix-profile/bin/nixd" },
    },
    "nil": {
      "binary": { "path": "~/.nix-profile/bin/nil" },
      "initialization_options": {
        "nix": {
          "flake": {
            "autoArchive": false,
          },
        },
      },
    },
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "nil"],
      "formatter": {
        "external": {
          "command": "alejandra",
          "arguments": ["--quiet", "--"],
        },
      },
      "format_on_save": "on",
    },
    "Lua": {
      "tab_size": 2,
      "hard_tabs": false,
      "auto_indent": "syntax_aware",
      "auto_indent_on_paste": true,
      "use_on_type_format": false,
    },
    "Python": {
      "language_servers": ["ty"],
      "formatter": {
        "language_server": { "name": "ruff" },
      },
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "auto_indent": "syntax_aware",
      "auto_indent_on_paste": true,
    },
  },
  "language_models": {
    "opencode": {
      "show_zen_models": false,
      "show_go_models": false,
    },
    "openai_compatible": {
      "llamacpp": {
        "api_url": "http://127.0.0.1:8080/v1",
        "available_models": [
          {
            "name": "qwen3.6-27b",
            "display_name": "Qwen3.6-27B",
            "max_tokens": 65536,
          },
          {
            "name": "qwen3.6-35b",
            "display_name": "Qwen3.6-35B",
            "max_tokens": 98304,
          },
        ],
      },
    },
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "fish",
        "args": ["-l"],
      },
    },
  },
  "show_whitespaces": "trailing",
  "vim_mode": true,
  "buffer_font_size": 15.0,
  "ui_font_size": 16.0,
  "ui_font_family": "Noto Sans",
  "buffer_font_family": "FiraCode Nerd Font",
  "theme": "Catppuccin Mocha",
  "format_on_save": "on",
  "load_direnv": "direct",
}
