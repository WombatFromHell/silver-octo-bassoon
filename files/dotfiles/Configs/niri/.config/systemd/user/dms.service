[Unit]
Description=DMS Service
PartOf=niri.service
After=niri.service
ConditionEnvironment=!DESKTOP_SESSION=plasma

[Service]
Type=simple
ExecStart=/usr/bin/dms run
ExecReload=/usr/bin/pkill -USR1 -x dms
Restart=on-failure
RestartSec=1.23
TimeoutStopSec=10

[Install]
WantedBy=graphical-session.target
