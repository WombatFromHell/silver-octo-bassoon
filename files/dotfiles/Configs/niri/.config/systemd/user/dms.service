[Unit]
Description=DMS Service
After=graphical-session.target
PartOf=niri.service
After=niri.service
ConditionEnvironment=!DESKTOP_SESSION=plasma

[Service]
Type=dbus
BusName=org.freedesktop.Notifications
ExecStart=/usr/bin/dms run --session
ExecReload=/usr/bin/pkill -USR1 -x dms
Restart=on-failure
RestartSec=1.23
TimeoutStopSec=10

[Install]
WantedBy=graphical-session.target
