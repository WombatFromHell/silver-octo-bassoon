[Unit]
Description=Kanshi Service
PartOf=niri.service
After=niri.service
ConditionEnvironment=!DESKTOP_SESSION=plasma

[Service]
Type=simple
ExecStart=/usr/bin/kanshi
ExecReload=/usr/bin/pkill --signal HUP -x kanshi
Restart=on-failure
RestartSec=1.23
TimeoutStop=10

[Install]
WantedBy=graphical-session.target
