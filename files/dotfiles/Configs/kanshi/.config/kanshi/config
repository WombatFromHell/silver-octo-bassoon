output "LG Electronics 27GL850 910NTGY7B319" {
    mode 2560x1440@144.000
    position 0,0
    alias $DESKTOP
}
output "LG Electronics LG TV SSCR2 0x01010101" {
  mode 2560x1440@120.000
  position 0,0
  alias $TV
}

profile notv {
    output $DESKTOP enable
    output $TV disable
    exec kanshi-runner.sh notv
}
profile tv {
    output $TV enable
    output $DESKTOP disable
    exec kanshi-runner.sh tv
}
profile desktop {
    output $DESKTOP enable
}
